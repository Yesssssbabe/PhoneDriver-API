# PhoneDriver API Configuration
# Copy this file to .env and fill in your API keys

# ==========================================
# Select Provider (uncomment one)
# ==========================================

# Option 1: Kimi Code (Recommended for China users)
# Get key from: https://kimi.com/code/console
PROVIDER=kimi_code
KIMI_CODE_API_KEY=sk-kimi-your-api-key-here
MODEL=kimi-for-coding

# Option 2: OpenRouter (Supports multiple models)
# Get key from: https://openrouter.ai/
# PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
# MODEL=moonshotai/kimi-k2.5

# Option 3: OpenAI
# Get key from: https://platform.openai.com/
# PROVIDER=openai
# OPENAI_API_KEY=sk-your-api-key-here
# MODEL=gpt-4o

# Option 4: Moonshot AI (Official)
# Get key from: https://platform.moonshot.cn/
# PROVIDER=moonshot
# MOONSHOT_API_KEY=sk-your-api-key-here
# MODEL=kimi-k2.5

# ==========================================
# Optional Settings
# ==========================================

# Temperature (0.0 - 1.0, default: 0.1)
# TEMPERATURE=0.1

# Max tokens (default: 512)
# MAX_TOKENS=512

# Step delay between actions in seconds (default: 1.5)
# STEP_DELAY=1.5

# Max retry attempts (default: 3)
# MAX_RETRIES=3
